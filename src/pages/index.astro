---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
import AvMiniAppBar from "../components/AvMiniAppBar.astro";

const title = "Lesson Builder | Ansiversa";
const description = "A premium manual lesson planning workspace for teachers.";
---

<AppShell title={title} description={description}>
  <AvMiniAppBar appKey="lesson-builder" appName="Lesson Builder" />

  <section class="py-20">
    <AvContainer size="narrow" className="space-y-8 text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Teacher-first planning workspace</p>
      <h1 class="text-4xl font-semibold text-white md:text-6xl">Build clear lessons with calm focus.</h1>
      <p class="mx-auto max-w-2xl text-lg text-slate-300">
        Plan objectives, materials, steps, and notes in one streamlined space. Keep favorites close, archive old plans safely,
        and stay organized without clutter.
      </p>
      <div class="flex justify-center">
        <AvButton href="/app">Open Lesson Builder</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="pb-20">
    <AvContainer className="grid gap-4 md:grid-cols-3">
      <article class="rounded-xl border border-white/10 bg-white/5 p-5">
        <h2 class="font-medium text-white">Structured plans</h2>
        <p class="mt-2 text-sm text-slate-300">Capture title, subject, topic, level, objective, materials, and flow in one lesson record.</p>
      </article>
      <article class="rounded-xl border border-white/10 bg-white/5 p-5">
        <h2 class="font-medium text-white">Fast organization</h2>
        <p class="mt-2 text-sm text-slate-300">Filter by subject, level, favorites, and archive state to find the right lesson in seconds.</p>
      </article>
      <article class="rounded-xl border border-white/10 bg-white/5 p-5">
        <h2 class="font-medium text-white">Connected to Ansiversa</h2>
        <p class="mt-2 text-sm text-slate-300">High-signal updates sync to your parent dashboard so progress is visible at a glance.</p>
      </article>
    </AvContainer>
  </section>
</AppShell>
