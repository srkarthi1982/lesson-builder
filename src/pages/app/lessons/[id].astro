---
import AppShell from "../../../layouts/AppShell.astro";
import AvMiniAppBar from "../../../components/AvMiniAppBar.astro";
import { AvContainer } from "@ansiversa/components";
import { getLessonDetailForUser, listLessonsForUser } from "../../../actions";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) {
  return new Response("Not found", { status: 404 });
}

const lesson = await getLessonDetailForUser(user.id, id);
if (!lesson) {
  return new Response("Not found", { status: 404 });
}

const lessons = await listLessonsForUser(user.id);
const payload = JSON.stringify({ lessons, activeLessonId: lesson.id });
---

<AppShell title={`${lesson.title} | Lesson Builder`} description="Lesson detail">
  <AvMiniAppBar appKey="lesson-builder" appName="Lesson Builder" />
  <main x-data="$store.lessonBuilder" x-init={`init(${payload.replace(/`/g, "\\`")})`} class="py-8">
    <AvContainer size="narrow" className="space-y-6">
      <a href="/app" class="text-sm text-cyan-200">← Back to workspace</a>

      <section class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h1 class="text-3xl font-semibold text-white" x-text="lessonForDetail?.title"></h1>
            <p class="mt-2 text-sm text-slate-300" x-text="[lessonForDetail?.subject, lessonForDetail?.topic, lessonForDetail?.level].filter(Boolean).join(' • ') || 'No subject/topic/level set yet.'"></p>
          </div>
          <button class="rounded border border-white/20 px-3 py-1 text-sm text-slate-200" @click="toggleFavorite(lessonForDetail)" x-text="lessonForDetail?.isFavorite ? '★ Favorited' : '☆ Favorite'"></button>
        </div>
        <div class="mt-4 grid gap-2 text-xs text-slate-400 md:grid-cols-2">
          <p>Created: <span x-text="new Date(lessonForDetail?.createdAt || '').toLocaleString()"></span></p>
          <p>Last updated: <span x-text="new Date(lessonForDetail?.updatedAt || '').toLocaleString()"></span></p>
        </div>
      </section>

      <section class="grid gap-4">
        <article class="rounded-xl border border-white/10 bg-white/5 p-5"><h2 class="text-sm font-semibold uppercase tracking-wide text-slate-200">Objective</h2><p class="mt-2 whitespace-pre-wrap text-slate-300" x-text="lessonForDetail?.objective || 'No objective added yet.'"></p></article>
        <article class="rounded-xl border border-white/10 bg-white/5 p-5"><h2 class="text-sm font-semibold uppercase tracking-wide text-slate-200">Materials</h2><p class="mt-2 whitespace-pre-wrap text-slate-300" x-text="lessonForDetail?.materialsText || 'No materials added yet.'"></p></article>
        <article class="rounded-xl border border-white/10 bg-white/5 p-5"><h2 class="text-sm font-semibold uppercase tracking-wide text-slate-200">Steps</h2><p class="mt-2 whitespace-pre-wrap text-slate-300" x-text="lessonForDetail?.stepsText || 'No steps added yet.'"></p></article>
        <article class="rounded-xl border border-white/10 bg-white/5 p-5"><h2 class="text-sm font-semibold uppercase tracking-wide text-slate-200">Notes</h2><p class="mt-2 whitespace-pre-wrap text-slate-300" x-text="lessonForDetail?.notes || 'No notes yet.'"></p></article>
      </section>

      <section class="flex gap-2">
        <button x-show="lessonForDetail?.status === 'active'" class="rounded border border-white/20 px-3 py-1 text-sm text-slate-200" @click="archiveLesson(lessonForDetail)">Archive lesson</button>
        <button x-show="lessonForDetail?.status === 'archived'" class="rounded border border-white/20 px-3 py-1 text-sm text-slate-200" @click="restoreLesson(lessonForDetail)">Restore lesson</button>
      </section>
    </AvContainer>
  </main>
</AppShell>
